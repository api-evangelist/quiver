        "type": "http"
      },
      "http": {
        "method": "GET",
        "url": "https://api.quiverquant.com/beta/historical/wikipedia/:ticker",
        "params": [
          {
            "name": "ticker",
            "value": "",
            "type": "path",
            "description": "Stock ticker symbol (e.g. AAPL)"
          }
        ]
